# ═══════════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id

# Razorpay Payment Gateway (KEY_ID only)
# WARNING: Never expose RAZORPAY_KEY_SECRET in frontend code!
# Get KEY_ID from https://dashboard.razorpay.com/settings/api-keys
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Optional: Backend URL override (for production deployments)
# Default: http://localhost:5000 (dev) or https://fasion-website-1.onrender.com (prod)
# REACT_APP_BACKEND_URL=https://your-backend-url.com
